___SANDBOXED_JS_FOR_WEB_TEMPLATE___

// Load template APIs
const injectScript = require('injectScript');
const setInWindow = require('setInWindow');
const createQueue = require('createQueue');
const makeTableMap = require('makeTableMap');
const log = require('logToConsole');

const SCRIPT_URL = 'https://app.productfruits.com/static/script.js';
const LOG_PREFIX = '[Product Fruits / GTM] ';

const fail = msg => {
  log(LOG_PREFIX + msg);
  data.gtmOnFailure();
};

if (!data.workspaceId) return fail('Missing Workspace ID.');
if (!data.username) return fail('Missing Username.');

const language = data.language || 'en';

const user = {
  username: data.username
};

if (data.userProperties && data.userProperties.length) {
  user.props = makeTableMap(data.userProperties, 'name', 'value');
}

// Prepare the globals expected by the Product Fruits loader.
setInWindow('productFruits', { scrV: '2' }, false);

// Queue the init call. Product Fruits processes the queue once the script loads.
// createQueue pushes a single value, so the init command is passed as one array
// (mirrors $productFruits.push(['init', workspaceId, language, user])).
const addToQueue = createQueue('$productFruits');
addToQueue(['init', data.workspaceId, language, user]);

injectScript(SCRIPT_URL, data.gtmOnSuccess, data.gtmOnFailure, 'productFruits');


